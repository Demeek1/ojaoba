# ============================================================
# OJAOBA.COM — Backend Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database (free at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/ojaoba?sslmode=require

# Admin auth — change this to a strong secret
# The ADMIN_EMAIL account is seeded as the protected "owner" (full access, all permissions).
ADMIN_JWT_SECRET=change_this_to_a_random_64_char_string
ADMIN_EMAIL=admin@ojaoba.com
ADMIN_PASSWORD=change_this_password

# AI — Adaeze shopping assistant (website + WhatsApp)
# Without ANTHROPIC_API_KEY the assistant still works via keyword search (degraded).
ANTHROPIC_API_KEY=sk-ant-your_key_here
ASSISTANT_MODEL=claude-haiku-4-5
# Optional: free Groq Whisper key for WhatsApp voice-note transcription
GROQ_API_KEY=

# Paystack (https://dashboard.paystack.com → Settings → API Keys)
PAYSTACK_SECRET_KEY=sk_live_your_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# WhatsApp Business Cloud API (from Meta Developer Dashboard)
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_VERIFY_TOKEN=ojaoba_verify_2024
WA_BUSINESS_ACCOUNT_ID=your_business_account_id

# Shopify (Settings → Apps → Develop apps → your app → API credentials)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# Your deployed backend URL (used in Paystack payment callback)
BACKEND_URL=https://your-backend.railway.app

# Delivery settings
DELIVERY_FEE_KOBO=50000
SUPPORT_PHONE=+234 800 000 0000
SUPPORT_EMAIL=support@ojaoba.com
