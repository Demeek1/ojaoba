# ============================================================
# OJAOBA ASSISTANT — Standalone AI chat website env
# Copy to .env.local and fill in your values
# ============================================================

# Ojaoba backend API (the shared brain — same backend as the main store)
# Dev:  http://localhost:4000/api
# Prod: https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Link back to the full storefront (shown as "Go to full store")
NEXT_PUBLIC_STORE_URL=https://www.ojaba.com

# Paystack public key (for in-chat checkout)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_key_here
