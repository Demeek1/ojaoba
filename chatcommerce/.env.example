# ─────────────────────────────────────────────────────────────
# ChatCommerce environment variables
# Copy to .env.local for local dev. On Vercel, set these in
# Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon recommended — serverless, scales to millions of rows)
# postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Session signing secret (JWT). Generate: openssl rand -base64 48
AUTH_SECRET=

# Master encryption key for vendor secrets at rest (AES-256-GCM).
# MUST be 32 bytes, base64-encoded. Generate: openssl rand -base64 32
# Losing/rotating this makes already-stored vendor tokens unreadable.
ENCRYPTION_KEY=

# The first account allowed to access /admin (super-admin / platform owner).
# Sign up with this exact email and it is auto-promoted to platform owner.
PLATFORM_OWNER_EMAIL=danielolanipekun551@gmail.com

# Public base URL of the deployed app (used to build webhook URLs shown to vendors)
# e.g. https://chatcommerce.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Billing (Stripe) — optional, gates vendors until they pay ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Set to "true" to require an active subscription before a vendor goes live.
BILLING_ENFORCED=false
